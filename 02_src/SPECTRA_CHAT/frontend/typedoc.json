{
  "$schema": "https://typedoc.org/schema.json",

  "entryPoints": ["src"],

  "entryPointStrategy": "expand",
  "tsconfig": "tsconfig.json",
  "exclude": ["**/*.vue"],
  "readme": "README.md",
  "projectDocuments": ["./*.md"],
  "excludeExternals": true,
  "excludePrivate": true,
  "excludeProtected": true,

  "skipErrorChecking": true,
  "plugin": ["typedoc-plugin-rename-defaults", "typedoc-plugin-inline-sources"],
  "blockTags": [
    "@returns",
    "@return",
    "@param",
    "@typeParam",
    "@see",
    "@example",
    "@remarks",
    "@source"
  ],
  "highlightLanguages": ["typescript", "javascript", "json", "bash"],
  "out": "typedoc"
}
