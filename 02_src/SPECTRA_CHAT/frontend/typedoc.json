{
  "$schema": "https://typedoc.org/schema.json",

  "entryPoints": ["src/**/*.ts"],

  "entryPointStrategy": "expand",

  "exclude": ["**/*.vue"],
  "readme": "README.md",
  "excludeExternals": true,
  "excludePrivate": true,
  "excludeProtected": true,

  "tsconfig": "./tsconfig.json",
  "skipErrorChecking": true,
  "plugin": ["typedoc-plugin-rename-defaults"],
  "out": "typedoc"
}
